LangString appRunning ${LANG_ENGLISH} "${PRODUCTNAME} is running! Please close it first, then try again."
LangString appRunningOkKill ${LANG_ENGLISH} "${PRODUCTNAME} is running.$\nClick OK to close it automatically."
LangString failedToKillApp ${LANG_ENGLISH} "Failed to close ${PRODUCTNAME}. Please close it manually, then try again."
