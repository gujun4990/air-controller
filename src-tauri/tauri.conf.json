{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AirController",
  "version": "0.1.26",
  "identifier": "com.opencodex.aircontroller",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AirController",
        "width": 780,
        "height": 540,
        "resizable": false,
        "minWidth": 780,
        "minHeight": 540,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "nsis": {
        "languages": [
          "English"
        ],
        "customLanguageFiles": {
          "English": "installer-languages/English.nsh"
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/icon.png"
    ]
  }
}
